PORT=3001
APP_URL=http://localhost:3000
DATA_DIR=./data
# Prisma resolves a relative file: URL against the prisma/ schema dir, so "../data"
# points at the same <repo>/data/24pray.db file the server uses (DATA_DIR above).
# In production use an absolute path, e.g. file:/opt/24pray-api/data/24pray.db
DATABASE_URL="file:../data/24pray.db"
SESSION_TTL_DAYS=30
COOKIE_SECURE=false
# Leave SMTP_URL empty in dev — magic links are logged to the console.
SMTP_URL=
SMTP_FROM=24pray <no-reply@24pray.local>
