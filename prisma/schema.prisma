generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  name           String
  role           String         @default("MEMBER") // MEMBER | ORGANIZER | ADMIN
  telegramChatId String?
  createdAt      DateTime       @default(now())
  projects       PrayerProject[] @relation("OrganizerProjects")
  slots          PrayerSlot[]
  magicTokens    MagicToken[]
  sessions       Session[]
}

model PrayerProject {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      String       @default("DRAFT") // DRAFT | ACTIVE | PAUSED | ARCHIVED
  visibility  String       @default("PRIVATE") // PUBLIC | PRIVATE
  startDate   DateTime
  endDate     DateTime
  timezone    String       @default("Europe/Berlin")
  inviteToken String       @unique
  organizerId String
  organizer   User         @relation("OrganizerProjects", fields: [organizerId], references: [id])
  createdAt   DateTime     @default(now())
  slots       PrayerSlot[]
}

model PrayerSlot {
  id            String        @id @default(cuid())
  projectId     String
  project       PrayerProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?         @relation(fields: [userId], references: [id])
  startTime     DateTime
  endTime       DateTime
  status        String        @default("BOOKED") // BOOKED | COMPLETED | CANCELLED
  guestName     String?
  guestEmail    String?
  notifyChannel String        @default("EMAIL") // EMAIL | TELEGRAM

  @@index([projectId, startTime])
}

model MagicToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime  @default(now())
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
}
